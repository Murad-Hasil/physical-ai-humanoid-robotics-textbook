# Frontend Environment Variables (Docusaurus uses DOCUSAURUS_ prefix)
# Copy this file to .env and update the values

# Backend API URL
DOCUSAURUS_API_URL=http://localhost:8000

# Feature Flags
DOCUSAURUS_HARDWARE_PROFILE_ENABLED=true
DOCUSAURUS_CURRICULUM_TRACKING_ENABLED=true

# Development
DOCUSAURUS_DEBUG_MODE=false
