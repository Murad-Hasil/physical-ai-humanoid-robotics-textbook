# Grok API Configuration
GROK_API_KEY=your_grok_api_key_here

# Qdrant Cloud Configuration
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Embedding & Chunking
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MAX_CHUNK_SIZE=500
CHUNK_OVERLAP=50
QDRANT_COLLECTION_NAME=physical-ai-docusaurus-textbook

# Grok Model Config
GROK_MODEL=grok-beta
GROK_API_TIMEOUT=30
GROK_MAX_RETRIES=3

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Database — Neon Serverless Postgres (recommended) or SQLite (dev)
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/neondb?sslmode=require
DATABASE_URL=sqlite:///./physical_ai.db

# Auth
BETTER_AUTH_SECRET=generate_with_python_secrets_token_urlsafe_32
JWT_SECRET=generate_with_python_secrets_token_urlsafe_32
JWT_EXPIRY_HOURS=24

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000
